# ── Provider selection ───────────────────────────────────────────────────────
# HERMIT_PROVIDER=claude

# ── Claude direct API ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# HERMIT_MODEL=claude-3-7-sonnet-latest

# ── Claude-compatible gateway / proxy ────────────────────────────────────────
# HERMIT_PROVIDER=claude
# HERMIT_AUTH_TOKEN=your-bearer-token
# HERMIT_BASE_URL=https://your-proxy.example.com/llm/claude
# HERMIT_CUSTOM_HEADERS=X-Biz-Id: hermit

# ── Codex via OpenAI Responses API ───────────────────────────────────────────
# HERMIT_PROVIDER=codex
# HERMIT_OPENAI_API_KEY=sk-...
# HERMIT_MODEL=gpt-5.4
# HERMIT_OPENAI_BASE_URL=https://api.openai.com/v1
# HERMIT_OPENAI_HEADERS=X-Project: hermit

# ── GitHub MCP (optional) ────────────────────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...
# GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/

# ── Codex OAuth (requires ~/.codex/auth.json) ────────────────────────────────
# HERMIT_PROVIDER=codex-oauth
# HERMIT_MODEL=gpt-5.4

# ── Feishu bot adapter (optional) ────────────────────────────────────────────
# HERMIT_FEISHU_APP_ID=cli_xxx
# HERMIT_FEISHU_APP_SECRET=your-app-secret
# HERMIT_FEISHU_THREAD_PROGRESS=true

# ── Scheduler / webhook (optional) ───────────────────────────────────────────
# HERMIT_SCHEDULER_FEISHU_CHAT_ID=oc_xxx
# HERMIT_WEBHOOK_ENABLED=true
# HERMIT_WEBHOOK_HOST=0.0.0.0
# HERMIT_WEBHOOK_PORT=8321

# ── Tuning (optional) ────────────────────────────────────────────────────────
# HERMIT_MAX_TOKENS=4096
# HERMIT_MAX_TURNS=50
# HERMIT_THINKING_BUDGET=8000
# HERMIT_LOG_LEVEL=INFO
# HERMIT_SANDBOX_MODE=l0
# HERMIT_COMMAND_TIMEOUT_SECONDS=30
# HERMIT_SESSION_IDLE_TIMEOUT_SECONDS=1800
