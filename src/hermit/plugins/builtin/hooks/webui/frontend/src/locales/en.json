          "description": "This is your main navigation. Each section manages a different part of Hermit — from projects and tasks to teams and tools."
        },
        "projectList": {
          "title": "Step 1: Select or Create a Project",
          "description": "Everything starts with a Project. A project groups related tasks, memories, and policies together. Click a project name on the left to open it, or use the + button to create your first one."
        },
        "createProject": {
          "title": "Create a New Project",
          "description": "Click this + button to create a project. Give it a clear name (e.g. \"Backend API\", \"Data Pipeline\"). You can have multiple projects for different work streams."
        },
        "projectTabs": {
          "title": "Project Detail Tabs",
          "description": "After selecting a project, you'll see these tabs:\n\n• Tasks — submit and monitor agent tasks\n• Memory — agent's accumulated knowledge\n• Signals — evidence signals from executions\n• Approvals — review pending approval requests\n• Policy — configure governance rules\n• Chat — direct conversation with the agent"
        },
        "taskInput": {
          "title": "Step 2: Submit Your First Task",
          "description": "Describe what you want the agent to do in natural language. For example: \"List all Python files in the project\" or \"Review the recent git commits\". Press Enter or click Send to submit."
        },
        "policySelector": {
          "title": "Choose Execution Policy",
          "description": "This controls how the agent executes:\n\n• Autonomous — the agent runs freely, no approval needed\n• Supervised — every action requires your manual approval\n• Default — uses the project's policy settings\n\nStart with Autonomous for simple tasks, use Supervised when you want full control."
        },
        "taskCards": {
          "title": "Step 3: Monitor Task Progress",
          "description": "After submitting, your task appears as a card here. The status dot shows its state:\n\n• Green (pulsing) — running\n• Yellow — blocked, waiting for approval\n• Green (solid) — completed successfully\n• Red — failed\n\nClick any card to see its full execution details on the right."
        },
        "taskDetailPanel": {
          "title": "Task Detail View",
          "description": "When you click a task card, the right panel shows the full execution details — steps taken, tools used, time elapsed, and the agent's response. This is where you inspect exactly what happened."
        },
        "stepTimeline": {
          "title": "Execution Steps & Receipts",
          "description": "Each step shows what the agent did:\n\n• Step name + duration at the top\n• Tool calls listed below (e.g. execute_command, read_file)\n• Green dot = succeeded, Red dot = failed\n• Click the ↺ icon to rollback a specific action\n\nIf a step is blocked (yellow clock), it's waiting for your approval in the Approvals tab."
        },
        "drawerChat": {
          "title": "Steer or Follow Up",
          "description": "While a task is running, type here to steer the agent (\"focus on the auth module\" or \"skip the tests\").\n\nAfter a task completes, this becomes a follow-up input — describe a continuation task and click \"New Task\" to chain tasks together."
        },
        "teams": {
          "title": "Teams",
          "description": "Teams organize multiple agents with different roles working on the same project. Each team has its own workspace and DAG-based workflow for complex multi-step operations."
        },
        "roles": {
          "title": "Roles",
          "description": "Roles define what an agent can do — which MCP servers it connects to and which skills it has. Create custom roles to give agents specialized capabilities."
        },
